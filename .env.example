progress.button.yandex="🟡"
progress.button.youtube="🔴"
progress.button.spotify="🟢"
progress.button.soundcloud="🟠"
progress.button.deezer="🟣"

loading.emoji="🔗"
disk.emoji="💿"

# Для плеера
buffer.emoji="📦"
lost.emoji="📥"
user.emoji="👤"

# Для действий внутри системы
queue.emoji="🎶"
current.emoji="▶️"
selected.emoji="➡ 🎵️"

# Визуалы под видом кнопок при проигрывании
# Как указывать правильные параметры
# ID - only int | discord emoji - ":string:" | emoji - "⚪️"
button.back="⏪"
button.resume="▶️"
button.pause="⏸"
button.skip="⏩"
button.loop="🔁"
button.loop_one="🔂"
button.shuffle="🔀"
button.autoplay="♾"

button.queue="📑"
button.lyrics="💽"
button.filters="🎛"
button.stop="🟥"