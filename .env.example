# Смайлики под видом прогресс бара (<:имя:ID>)
# Как указывать правильные параметры
# ID - <:name:id> | discord emoji - ":string:" | emoji - "⚪️"

progress.empty.left="="
progress.empty.right="="
progress.empty.center="=-"
progress.not_empty.left="-"
progress.not_empty.right="-"
progress.not_empty.center="-="

progress.button="⚪️"
