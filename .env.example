#development, production
NODE_ENV="production"









########################################################################################################
#  _____           _       __     _____ _____
# |  __ \         | |     / /\   |  __ \_   _|
# | |__) |___  ___| |_   / /  \  | |__) || |
# |  _  // _ \/ __| __| / / /\ \ |  ___/ | |
